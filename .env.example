# Copy to .env and adjust before: docker compose up --build
# cp .env.example .env

# PostgreSQL
POSTGRES_USER=uniclub
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=uniclub
POSTGRES_PORT=5432

# App
APP_PORT=8080
APP_URL=http://localhost:8080

# Auth (required — min 32 chars)
JWT_KEY=replace_with_secure_random_key_at_least_32_chars
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# Cloudinary (required by API startup; use real values in production)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (optional for local docker demo)
SENDGRID_API_KEY=
SENDGRID_FROM_NAME=UniClub Hub
SENDGRID_FROM_ADDRESS=noreply@example.com

# Gemini AI (optional — role suggestions fall back to rules without key)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
